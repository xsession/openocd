# Host-side Linux udev rules for common probes.
# Copy to /etc/udev/rules.d/99-openocd-probes.rules, then run:
#   sudo udevadm control --reload-rules && sudo udevadm trigger
# Docker still needs --device /dev/bus/usb or privileged access.

# ST-Link/V2, V2-1, V3
SUBSYSTEM=="usb", ATTR{idVendor}=="0483", MODE="0666", GROUP="plugdev", TAG+="uaccess"
# CMSIS-DAP common DAPLink
SUBSYSTEM=="usb", ATTR{idVendor}=="0d28", MODE="0666", GROUP="plugdev", TAG+="uaccess"
# SEGGER J-Link
SUBSYSTEM=="usb", ATTR{idVendor}=="1366", MODE="0666", GROUP="plugdev", TAG+="uaccess"
# FTDI
SUBSYSTEM=="usb", ATTR{idVendor}=="0403", MODE="0666", GROUP="plugdev", TAG+="uaccess"
# Texas Instruments XDS110
SUBSYSTEM=="usb", ATTR{idVendor}=="0451", ATTR{idProduct}=="bef3", MODE="0666", GROUP="plugdev", TAG+="uaccess"
SUBSYSTEM=="usb", ATTR{idVendor}=="0451", ATTR{idProduct}=="bef4", MODE="0666", GROUP="plugdev", TAG+="uaccess"
SUBSYSTEM=="usb", ATTR{idVendor}=="1cbe", ATTR{idProduct}=="02a5", MODE="0666", GROUP="plugdev", TAG+="uaccess"
# Olimex ARM-USB-OCD
SUBSYSTEM=="usb", ATTR{idVendor}=="15ba", MODE="0666", GROUP="plugdev", TAG+="uaccess"

# Microchip PICkit 2 and PICkit 3 scripting programmer modes
SUBSYSTEM=="usb", ATTR{idVendor}=="04d8", ATTR{idProduct}=="0033", MODE="0660", GROUP="plugdev", TAG+="uaccess"
SUBSYSTEM=="usb", ATTR{idVendor}=="04d8", ATTR{idProduct}=="900a", MODE="0660", GROUP="plugdev", TAG+="uaccess"
# Microchip PICkit 4 and ICD 4 CMSIS-DAP/HID interfaces
SUBSYSTEM=="usb", ATTR{idVendor}=="03eb", ATTR{idProduct}=="2177", MODE="0660", GROUP="plugdev", TAG+="uaccess"
SUBSYSTEM=="usb", ATTR{idVendor}=="03eb", ATTR{idProduct}=="217c", MODE="0660", GROUP="plugdev", TAG+="uaccess"
