{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "F28M35x C28x via OpenOCD/XDS100v2",
      "type": "c2000-debug",
      "request": "attach",
      "backend": "openocd",
      "device": "tms320f28m35x_c28x",
      "openocdHost": "127.0.0.1",
      "openocdTelnetPort": 4444,
      "svdPath": "${workspaceFolder}/svd/tms320f28m35x_c28x.svd",
      "addressScale": 2,
      "registerProfile": "c28x"
    }
  ]
}
