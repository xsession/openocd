# Texas Instruments XDS100v2 and XDS100v3
ACTION!="add|change", GOTO="openocd_xds100_end"
SUBSYSTEM!="usb", GOTO="openocd_xds100_end"
ATTRS{idVendor}=="0403", ATTRS{idProduct}=="a6d0", MODE="0660", GROUP="plugdev", TAG+="uaccess"
ATTRS{idVendor}=="0403", ATTRS{idProduct}=="a6d1", MODE="0660", GROUP="plugdev", TAG+="uaccess"
LABEL="openocd_xds100_end"
