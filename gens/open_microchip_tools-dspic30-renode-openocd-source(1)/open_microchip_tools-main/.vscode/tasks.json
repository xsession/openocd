{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "open-microchip-tools: compile extension",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "compile"
      ],
      "options": {
        "cwd": "${workspaceFolder}/vscode_extension"
      },
      "problemMatcher": [
        "$tsc"
      ],
      "group": "build"
    },
    {
      "label": "open-microchip-tools: watch extension",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "watch"
      ],
      "options": {
        "cwd": "${workspaceFolder}/vscode_extension"
      },
      "isBackground": true,
      "problemMatcher": [
        "$tsc-watch"
      ]
    }
  ]
}