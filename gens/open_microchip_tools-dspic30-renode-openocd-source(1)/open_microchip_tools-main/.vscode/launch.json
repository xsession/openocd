{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Open Microchip Tools Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode_extension"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode_extension/out/**/*.js"
      ],
      "preLaunchTask": "open-microchip-tools: compile extension"
    }
  ]
}