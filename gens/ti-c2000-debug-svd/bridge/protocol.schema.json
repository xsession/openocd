{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "C2000 CCS bridge JSON-lines protocol",
  "oneOf": [
    {
      "type": "object",
      "required": ["id", "method", "params"],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "method": { "type": "string" },
        "params": { "type": "object" }
      }
    },
    {
      "type": "object",
      "required": ["id", "ok"],
      "properties": {
        "id": { "type": "integer" },
        "ok": { "type": "boolean" },
        "result": {},
        "error": { "type": "object" }
      }
    },
    {
      "type": "object",
      "required": ["event"],
      "properties": {
        "event": { "enum": ["stopped", "continued", "output", "terminated"] },
        "coreId": { "type": "integer" },
        "reason": { "type": "string" },
        "text": { "type": "string" }
      }
    }
  ]
}
