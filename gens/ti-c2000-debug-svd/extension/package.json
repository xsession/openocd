{
  "name": "c2000-debug",
  "displayName": "TI C2000 Debug",
  "description": "VS Code Debug Adapter for TI C2000 C28x devices using CCS Scripting, OpenOCD telnet, or a deterministic mock backend.",
  "version": "0.1.0",
  "publisher": "codelayer",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Debuggers"
  ],
  "keywords": [
    "C2000",
    "C28x",
    "TMS320F28069",
    "TMS320F280049",
    "F28M35x",
    "CCS",
    "XDS110"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onDebug:c2000-debug"
  ],
  "contributes": {
    "debuggers": [
      {
        "type": "c2000-debug",
        "label": "TI C2000 Debug",
        "runtime": "node",
        "program": "./dist/adapter.js",
        "languages": [
          "c",
          "cpp",
          "asm"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "backend",
              "device"
            ],
            "properties": {
              "backend": {
                "type": "string",
                "enum": [
                  "ccs",
                  "openocd",
                  "mock"
                ],
                "description": "Debugger transport. CCS is the production backend; mock is for CI; OpenOCD currently provides low-level control."
              },
              "device": {
                "type": "string",
                "enum": [
                  "tms320f28069",
                  "tms320f280049",
                  "tms320f28m35x_c28x",
                  "tms320f28m35x_m3"
                ]
              },
              "request": {
                "type": "string",
                "enum": [
                  "launch",
                  "attach"
                ]
              },
              "executable": {
                "type": "string",
                "description": "TI ELF/COFF .out file to load."
              },
              "ccsRoot": {
                "type": "string",
                "description": "Code Composer Studio installation root, for example C:/ti/ccs2040."
              },
              "ccxml": {
                "type": "string",
                "description": "Working TI target configuration file."
              },
              "corePattern": {
                "type": "string",
                "description": "Exact or regular-expression core selector passed to CCS Scripting openSession()."
              },
              "cores": {
                "type": "array",
                "description": "Optional multi-core session definitions. Each core becomes a DAP thread.",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "pattern",
                    "architecture"
                  ],
                  "properties": {
                    "name": { "type": "string" },
                    "pattern": { "type": "string" },
                    "architecture": {
                      "type": "string",
                      "enum": ["c28x", "cortex-m3"]
                    },
                    "device": { "type": "string" },
                    "executable": { "type": "string" },
                    "loadProgram": { "type": "boolean", "default": true },
                    "addressScale": { "type": "integer", "enum": [1, 2] }
                  }
                }
              },
              "svdPath": {
                "type": "string",
                "description": "Byte-addressed CMSIS-SVD consumed by MCU Peripheral Viewer."
              },
              "addressScale": {
                "type": "integer",
                "enum": [
                  1,
                  2
                ],
                "default": 2,
                "description": "Bytes per target address unit. Use 2 for C28x and 1 for Cortex-M."
              },
              "runToEntryPoint": {
                "type": ["string", "null"],
                "default": "main"
              },
              "stopOnEntry": {
                "type": "boolean",
                "default": false
              },
              "resetOnLaunch": {
                "type": "boolean",
                "default": false
              },
              "verifyProgram": {
                "type": "boolean",
                "default": false
              },
              "bridgeScript": {
                "type": "string",
                "description": "Override the bundled CCS JSON bridge script."
              },
              "bridgeCommand": {
                "type": "string",
                "description": "Optional executable used instead of CCS scripting run.bat/run.sh."
              },
              "bridgeArgs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "openocdHost": {
                "type": "string",
                "default": "127.0.0.1"
              },
              "openocdTelnetPort": {
                "type": "integer",
                "default": 4444
              },
              "registerProfile": {
                "type": "string",
                "enum": [
                  "auto",
                  "c28x",
                  "c28x-fpu-vcu",
                  "c28x-fpu-tmu-vcu",
                  "cortex-m3"
                ],
                "default": "auto"
              },
              "trace": {
                "type": "boolean",
                "default": false
              }
            }
          },
          "attach": {
            "required": [
              "backend",
              "device"
            ],
            "properties": {
              "backend": {
                "type": "string",
                "enum": ["ccs", "openocd", "mock"]
              },
              "device": { "type": "string" },
              "ccsRoot": { "type": "string" },
              "ccxml": { "type": "string" },
              "corePattern": { "type": "string" },
              "svdPath": { "type": "string" },
              "addressScale": { "type": "integer", "enum": [1, 2] },
              "trace": { "type": "boolean", "default": false }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "C2000: CCS launch",
            "type": "c2000-debug",
            "request": "launch",
            "backend": "ccs",
            "device": "tms320f28069",
            "ccsRoot": "C:/ti/ccs2040",
            "ccxml": "${workspaceFolder}/targetConfigs/F28069_XDS110.ccxml",
            "corePattern": "C28xx",
            "executable": "${workspaceFolder}/Debug/app.out",
            "svdPath": "${workspaceFolder}/svd/tms320f28069.svd",
            "addressScale": 2,
            "runToEntryPoint": "main"
          }
        ],
        "configurationSnippets": [
          {
            "label": "C2000: CCS launch",
            "description": "Launch a C28x target through TI CCS Scripting.",
            "body": {
              "name": "C2000: CCS ${1:device}",
              "type": "c2000-debug",
              "request": "launch",
              "backend": "ccs",
              "device": "${1:tms320f28069}",
              "ccsRoot": "${2:C:/ti/ccs2040}",
              "ccxml": "${workspaceFolder}/${3:targetConfigs/device.ccxml}",
              "corePattern": "${4:C28xx}",
              "executable": "${workspaceFolder}/${5:Debug/app.out}",
              "svdPath": "${workspaceFolder}/svd/${1:tms320f28069}.svd",
              "addressScale": 2,
              "runToEntryPoint": "main"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "clean": "node scripts/clean.js",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.js",
    "package": "npm run build && node scripts/package-vsix.js"
  }
}
